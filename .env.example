# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=sistren
DATABASE_URL="mysql://root:root@localhost:3306/sistren"

# Better Auth
BETTER_AUTH_SECRET=<generate with: openssl rand -base64 32>
BETTER_AUTH_URL=http://localhost:3000

# Document Encryption (AES-256-GCM)
# Generate with: openssl rand -hex 32
DOCUMENT_ENCRYPTION_KEY=<32-byte hex key, generate with: openssl rand -hex 32>

# App URL (change to your IP when accessing from other devices)
# NEXT_PUBLIC_APP_URL=http://192.168.1.29:3000

# Enable quick logins
ENABLE_QUICK_LOGINS_DEMO=false

# Enable quick logins
NEXT_PUBLIC_ENABLE_DEMO_LOGIN=true
NEXT_PUBLIC_DEMO_PASSWORD=Password123!
NEXT_PUBLIC_DEMO_SUPERADMIN_EMAIL=superadmin@sister.com
NEXT_PUBLIC_DEMO_ADMIN_EMAIL=admin@sister.com
NEXT_PUBLIC_DEMO_GURU_EMAIL=guru@sister.com
NEXT_PUBLIC_DEMO_SISWA_EMAIL=siswa@sister.com
NEXT_PUBLIC_DEMO_ALUMNI_EMAIL=alumni@sister.com
