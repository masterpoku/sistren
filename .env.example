# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=sistren
DATABASE_URL="mysql://root:root@localhost:3306/sistren"

# Better Auth
BETTER_AUTH_SECRET=<generate with: openssl rand -base64 32>
BETTER_AUTH_URL=http://localhost:3000

# Document Encryption (AES-256-GCM)
# Generate with: openssl rand -hex 32
DOCUMENT_ENCRYPTION_KEY=<32-byte hex key, generate with: openssl rand -hex 32>

# Enable quick logins
ENABLE_QUICK_LOGINS_DEMO=false
